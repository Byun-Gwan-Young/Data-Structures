#include <stdio.h>

int main() {
    /* [과제 1 설명]
 * 1. 숫자 1의 비트 패턴(0001)을 반전(~1)하면 '11111110'이 됩니다.
 * 2. 만약 시스템이 '1의 보수' 체계라면: 
 * - 비트를 뒤집는 것만으로 음수가 표현되므로, '11111110'을 바로 '-1'로 읽습니다.
 * 3. 만약 시스템이 '2의 보수' 체계라면: 
 * - '비트 반전 후 1을 더해야' 음수가 완성됩니다. 
 * - 즉, '11111110'은 아직 1을 더하기 전의 상태입니다. 
 * - 이 값을 역추적(1을 빼고 비트 반전)하면 숫자 2가 나오므로, 시스템은 이를 '-2'로 읽습니다.
 * - (참고: 2의 보수에서 진짜 '-1'은 '11111111'입니다.)
 * 4. 따라서 실행 결과 ~1이 -2로 출력되면 현재 PC는 '2의 보수' 방식을 사용하는 것입니다.
 * - (참고 : 다른 방식이 있을 수 있으니 기타 방식까지 추가하였습니다.)
 */
    
    int n = 1;


    if (~n == -2) {
        printf("2의 보수입니다.\n");
    } else if (~n == -1) {
        printf("1의 보수입니다.\n");
    } else {
        printf("기타 방식입니다.\n");
    }

    return 0;
}
